{
  "name": "cartel-scraper",
  "version": "2.1.2",
  "private": true,
  "description": "Standalone scraper outside Next.js app with Anthropic + OpenAI variants",
  "type": "module",
  "scripts": {
    "scrape": "node scrape-anthropic.mjs",
    "scrape:quick": "node scrape-anthropic.mjs --limit 10",
    "scrape:dry": "node scrape-anthropic.mjs --dry-run",
    "scrape:anthropic": "node scrape-anthropic.mjs",
    "scrape:openai": "node scrape-openai.mjs",
    "anthropic": "node scrape-anthropic.mjs",
    "openai": "node scrape-openai.mjs",
    "check": "node --check scrape-anthropic.mjs && node --check scrape-openai.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "axios": "^1.7.7",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "openai": "^4.63.0"
  }
}
